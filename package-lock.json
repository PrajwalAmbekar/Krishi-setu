{
  "name": "krishi-setu",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "krishi-setu",
      "version": "1.0.0",
      "workspaces": [
        "app/*",
        "worker/*",
        "packages/*"
      ]
    },
    "app/api": {
      "name": "@krishi/api",
      "version": "1.0.0"
    },
    "node_modules/@krishi/api": {
      "resolved": "app/api",
      "link": true
    },
    "node_modules/@krishi/match-worker": {
      "resolved": "worker/match-worker",
      "link": true
    },
    "node_modules/@krishi/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/shared": {
      "name": "@krishi/shared",
      "version": "1.0.0"
    },
    "worker/match-worker": {
      "name": "@krishi/match-worker",
      "version": "1.0.0"
    }
  }
}
