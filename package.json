{
  "name": "krishi-setu",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "app/*",
    "worker/*",
    "packages/*"
  ],
"scripts": {
    "dev": "npm run dev --workspace=@krishi/api",
    "dev:api": "npm run dev --workspace=@krishi/api",
    "dev:worker": "npm run dev --workspace=@krishi/match-worker",
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "typecheck:workspaces": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
